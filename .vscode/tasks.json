{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run (stdin)",
      "type": "shell",
      "command": "node \"${file}\" < \"${fileDirname}/input.txt\"",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run (no stdin)",
      "type": "shell",
      "command": "node \"${file}\"",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
